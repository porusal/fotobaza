{
  "name": "foto636/gallery-site",
  "type": "project",
  "description": "Laravel gallery site for photos, albums, pages, and settings.",
  "keywords": [
    "laravel",
    "gallery",
    "photos",
    "sqlite"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "intervention/image": "^3.11",
    "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
    "laravel/ui": "^4.6",
        "pragmarx/google2fa-laravel": "^3.0",
    "simplesoftwareio/simple-qrcode": "^4.2"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "laravel/pail": "^1.2",
    "laravel/pint": "^1.22",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.8",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd\" \"php artisan serve\" \"npm run dev\""
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test --ansi"
    ],
    "format": [
      "vendor/bin/pint"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
