APP_NAME="Foto 636"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_DATABASE_ENABLED=false
FILESYSTEM_DISK=public
FILESYSTEM_PUBLIC_ROOT=public/storage
GALLERY_FILESYSTEM_SYNC=true
GALLERY_FILESYSTEM_AUTO_SYNC=true
GALLERY_FILESYSTEM_AUTO_SYNC_SECONDS=30
GALLERY_FILESYSTEM_PHOTOS_DIR=photos
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@foto.636.ovh"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
